                 int(m.get("importance", 5)), m.get("expires_at"),
                 m.get("created_at") or now_iso(), m.get("updated_at") or now_iso()),
            )
            conn.execute(
                "INSERT INTO memories_audit (memory_id, action, content_before, "
                "content_after, timestamp) VALUES (?, 'create', NULL, ?, ?)",
                (cur.lastrowid, m["content"], now_iso()))
            n_mem += 1
        if not args.no_messages:
            for ms in payload.get("messages", []):
                conn.execute(
                    """
                    INSERT INTO messages
                        (project, request_id, agent, direction, channel, status,
                         content, tokens_in, tokens_out, timestamp)
                    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                    """,
                    (target, ms.get("request_id"), ms["agent"], ms["direction"],
                     ms.get("channel"), ms.get("status"), ms["content"],
                     ms.get("tokens_in"), ms.get("tokens_out"),
                     ms.get("timestamp") or now_iso()))
                n_msg += 1
        conn.commit()
        if args.json:
            json.dump({"restored_to": target, "memories": n_mem,
                       "messages": n_msg}, sys.stdout); sys.stdout.write("\n")
        else:
            print(f"restored archive #{args.id} into {target}: "
                  f"{n_mem} memories, {n_msg} messages")
        return

    if args.action == "delete":
        row = conn.execute("SELECT id FROM archives WHERE id = ?",
                           (args.id,)).fetchone()
