def _ollama_generate(prompt: str, model: str, host: str,
                     timeout_s: int = 240) -> Optional[str]:
    """POST to Ollama /api/generate, return the response text or None on
    any failure (network, non-200, malformed body, empty result)."""
    import urllib.request, urllib.error
    body = {
        "model": model,
        "prompt": prompt,
        "stream": False,
        "options": {"temperature": 0.2, "num_predict": 4096, "num_ctx": 32768},
    }
    try:
        req = urllib.request.Request(
            f"{host}/api/generate",
            data=json.dumps(body).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=timeout_s) as resp:
            if resp.status != 200:
                return None
            payload = json.loads(resp.read().decode("utf-8"))
            text = (payload.get("response") or "").strip()
            return text or None
    except (urllib.error.URLError, ConnectionError, TimeoutError, OSError,
            json.JSONDecodeError):
        return None


def _ollama_available(host: str, model: str) -> bool:
    """Ping /api/tags and confirm the requested model is installed."""
    import urllib.request, urllib.error
    try:
        with urllib.request.urlopen(f"{host}/api/tags", timeout=5) as resp:
            if resp.status != 200:
                return False
            tags = json.loads(resp.read().decode("utf-8")).get("models", [])
        names = [m.get("name", "") for m in tags]
        return any(n == model or n.startswith(f"{model}:") or n.startswith(f"{model}-")
                   for n in names)
    except Exception:
        return False


def _select_compactable(conn: sqlite3.Connection, project: str,
                        chat_older: _dt.timedelta, keep_last: int) -> list:
    """Messages older than `chat_older` AND outside the most-recent
    `keep_last` rows for this project."""
    cutoff = (_dt.datetime.now(_dt.timezone.utc) - chat_older) \
                .strftime("%Y-%m-%dT%H:%M:%SZ")
    # First find the id of the (keep_last+1)th-most-recent message; everything
    # older AND older than the time cutoff is fair game.
    row = conn.execute(
        "SELECT id FROM messages WHERE project = ? "
        "ORDER BY id DESC LIMIT 1 OFFSET ?",
        (project, keep_last),
    ).fetchone()
    if not row:
        return []
    keep_threshold_id = row["id"]
    return conn.execute(
        "SELECT id, request_id, agent, direction, channel, status, content, "
        "timestamp FROM messages "
        "WHERE project = ? AND id <= ? AND timestamp < ? "
        "ORDER BY id ASC",
        (project, keep_threshold_id, cutoff),
    ).fetchall()


def _chunk_messages(rows: list, target_chars: int) -> list[list]:
    """Group consecutive rows into chunks of approximately `target_chars`
    bytes worth of content. Each chunk preserves message order."""
    if not rows:
        return []
    chunks: list[list] = [[]]
    cur_chars = 0
    for r in rows:
        line_len = len(r["content"] or "") + 50  # accounting for header
        if cur_chars + line_len > target_chars and chunks[-1]:
            chunks.append([])
            cur_chars = 0
        chunks[-1].append(r)
        cur_chars += line_len
    return [c for c in chunks if c]


def _render_chunk_text(rows: list) -> str:
    """Format a chunk of messages as markdown for the Ollama prompt."""
    out = []
    for r in rows:
        arrow = "→" if r["direction"] == "out" else "←"
        head = f"### {r['timestamp']} {arrow} {r['agent']}"
        if r["status"]:
            head += f"  ({r['status']})"
        if r["request_id"]:
            head += f"  [{r['request_id'][:24]}]"
        out.append(head)
        out.append(r["content"] or "")
        out.append("")
    return "\n".join(out)


def cmd_compact(args: argparse.Namespace) -> None:
    chat_older = parse_duration(args.chat_older)
    keep_last = args.keep_last
    host = args.ollama_host
    model = args.model

    conn = connect(); migrate(conn)

    # Pick projects: --session restricts; otherwise process all.
    if args.session:
        projects = [expand_path(args.session)]
    elif args.all_sessions:
        projects = [r["path"] for r in conn.execute(
            "SELECT path FROM projects").fetchall()]
    else:
        projects = [resolve_project(None)]

    plan: list[dict] = []
    for proj in projects:
        rows = _select_compactable(conn, proj, chat_older, keep_last)
        if not rows:
            continue
        chunks = _chunk_messages(rows, args.chunk_chars)
        total_chars = sum(len(r["content"] or "") for r in rows)
        plan.append({
            "project": proj,
            "messages_to_compact": len(rows),
            "chunks": len(chunks),
            "raw_chars": total_chars,
            "id_range": (rows[0]["id"], rows[-1]["id"]),
            "date_range": (rows[0]["timestamp"], rows[-1]["timestamp"]),
            "chunk_rows": chunks,
        })

    if not plan:
        print("compact: nothing eligible (no messages older than threshold + outside keep window)")
        if args.json:
            json.dump({"projects": [], "dry_run": bool(args.dry_run)}, sys.stdout); sys.stdout.write("\n")
        return

    if args.dry_run:
        # Surface plan without doing anything.
        print(f"compact dry-run: {len(plan)} project(s), "
              f"--chat-older={args.chat_older} --keep-last={keep_last}")
        for p in plan:
            print(f"  {p['project']}")
            print(f"    messages: {p['messages_to_compact']}  "
                  f"chunks: {p['chunks']}  raw_chars: {p['raw_chars']:,}")
            print(f"    id range: {p['id_range'][0]}..{p['id_range'][1]}  "
                  f"date range: {p['date_range'][0]}..{p['date_range'][1]}")
        if args.json:
            for p in plan:
                p.pop("chunk_rows", None)
            json.dump({"projects": plan, "dry_run": True}, sys.stdout, indent=2, default=str); sys.stdout.write("\n")
        return

    # Live run — confirm Ollama first. We refuse to delete anything if Ollama
    # isn't reachable so old chat is never lost without a summary in place.
    if not _ollama_available(host, model):
        die(f"Ollama unavailable or model {model!r} not installed at {host}. "
            f"Aborted with no changes. Pull the model with: ollama pull {model}")

    total_summarised = 0
    total_deleted = 0
    failures: list[str] = []
    for p in plan:
        proj = p["project"]
        for chunk_rows in p["chunk_rows"]:
            chunk_text = _render_chunk_text(chunk_rows)
            prompt = COMPACT_PROMPT + "\n" + chunk_text + "\n\nSUMMARY:\n"
            print(f"  [{proj}] summarising chunk of {len(chunk_rows)} msgs "
                  f"(~{len(chunk_text):,} chars)...", file=sys.stderr)
            summary = _ollama_generate(prompt, model, host)
            if not summary:
                failures.append(f"{proj}: chunk {chunk_rows[0]['id']}..{chunk_rows[-1]['id']} "
                                "ollama returned no result; aborting whole compact run")
                break

            id_min = chunk_rows[0]["id"]
            id_max = chunk_rows[-1]["id"]
            ts_min = chunk_rows[0]["timestamp"]
            ts_max = chunk_rows[-1]["timestamp"]
            now = now_iso()
            cur = conn.execute(
                """
                INSERT INTO memories
                    (project, category, key, content, importance, expires_at,
                     created_at, updated_at)
                VALUES (?, 'chat_summary', ?, ?, 4, NULL, ?, ?)
                """,
                (proj, f"compact:{id_min}-{id_max}",
                 (f"_Compaction summary of messages {id_min}..{id_max} "
                  f"({ts_min} → {ts_max}, {len(chunk_rows)} messages)._\n\n{summary}"),
                 now, now),
            )
            mem_id = cur.lastrowid
            conn.execute(
                "INSERT INTO memories_audit (memory_id, action, content_before, "
                "content_after, timestamp) VALUES (?, 'create', NULL, ?, ?)",
                (mem_id, summary[:500], now))
            # Now delete the source messages.
            conn.execute("DELETE FROM messages WHERE id BETWEEN ? AND ? AND project = ?",
                         (id_min, id_max, proj))
            total_deleted += len(chunk_rows)
            total_summarised += 1
        if failures:
            break

    conn.commit()
    if failures:
        for f in failures:
            print(f"compact ERROR: {f}", file=sys.stderr)
        sys.exit(2)

    if args.json:
        json.dump({"summaries_created": total_summarised,
                   "messages_deleted": total_deleted,
                   "dry_run": False}, sys.stdout, indent=2)
        sys.stdout.write("\n")
    else:
        print(f"compact: created {total_summarised} chat_summary memories, "
              f"deleted {total_deleted} messages")


def cmd_message_add(args: argparse.Namespace) -> None:
    """Internal: insert a row into messages. Used by buck-review.sh to log
    every exchange. Auto-creates the project row so callers don't need to
    init explicitly."""
    proj = resolve_project(args.session)
    conn = connect(); migrate(conn)
    ensure_project(conn, proj)

    # Resolve content from --content or stdin.
    content: str
    if args.content_stdin:
        content = sys.stdin.read()
    elif args.content is not None:
        content = args.content
    else:
        die("provide --content or --content-stdin")

    # Map permissive agent names to the schema-allowed enum.
    agent_map = {"chatgpt": "gpt", "cursor": "gpt"}
    agent = agent_map.get(args.agent, args.agent)
    if agent not in ("user", "claude", "gpt", "codex", "buck"):
        die(f"unknown agent: {args.agent}")

    cur = conn.execute(
        """
        INSERT INTO messages
            (project, request_id, agent, direction, channel, status,
             content, tokens_in, tokens_out, timestamp)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (proj, args.request_id, agent, args.direction, args.channel,
         args.status, content, args.tokens_in, args.tokens_out, now_iso()),
    )
    msg_id = cur.lastrowid
    conn.commit()

    if args.json:
        json.dump({"id": msg_id, "project": proj}, sys.stdout); sys.stdout.write("\n")
    else:
        print(f"logged msg id={msg_id}  {args.direction} {agent}")


def cmd_prune(args: argparse.Namespace) -> None:
    conn = connect(); migrate(conn)
    n = conn.execute(
        "SELECT COUNT(*) c FROM memories WHERE expires_at IS NOT NULL AND expires_at < ?",
        (now_iso(),)
    ).fetchone()["c"]
    if not args.dry_run:
        conn.execute("DELETE FROM memories WHERE expires_at IS NOT NULL AND expires_at < ?",
                     (now_iso(),))
        conn.commit()
    if args.json:
        json.dump({"pruned": n, "dry_run": bool(args.dry_run)}, sys.stdout); sys.stdout.write("\n")
    else:
        word = "would prune" if args.dry_run else "pruned"
        print(f"{word} {n} expired memories")


def cmd_doctor(args: argparse.Namespace) -> None:
    conn = connect(); migrate(conn)
    counts = {
        "projects": conn.execute("SELECT COUNT(*) c FROM projects").fetchone()["c"],
        "memories": conn.execute("SELECT COUNT(*) c FROM memories").fetchone()["c"],
        "memories_audit": conn.execute("SELECT COUNT(*) c FROM memories_audit").fetchone()["c"],
        "messages": conn.execute("SELECT COUNT(*) c FROM messages").fetchone()["c"],
    }
    # Orphan checks.
    orphan_messages = conn.execute(
        "SELECT COUNT(*) c FROM messages "
        "WHERE project NOT IN (SELECT path FROM projects)"
    ).fetchone()["c"]
    orphan_memories = conn.execute(
        "SELECT COUNT(*) c FROM memories "
        "WHERE project IS NOT NULL AND project NOT IN (SELECT path FROM projects)"
    ).fetchone()["c"]
    pragma_version = conn.execute("PRAGMA user_version").fetchone()[0]
    db_size = DB_PATH.stat().st_size if DB_PATH.exists() else 0
    out = {
        "db_path": str(DB_PATH),
        "db_size_bytes": db_size,
        "pragma_user_version": pragma_version,
        "counts": counts,
        "orphan_messages": orphan_messages,
        "orphan_memories": orphan_memories,
        "status": "OK" if orphan_messages == 0 and orphan_memories == 0 else "WARN",
    }
    if args.json:
        json.dump(out, sys.stdout, indent=2); sys.stdout.write("\n")
    else:
        print(f"db: {DB_PATH} ({db_size:,} B)  schema_v{pragma_version}  status: {out['status']}")
        for k, v in counts.items():
            print(f"  {k:16s} {v}")
        if orphan_messages or orphan_memories:
            print(f"  orphan_messages  {orphan_messages}")
            print(f"  orphan_memories  {orphan_memories}")


# ---------- argparse plumbing ----------


def build_parser() -> argparse.ArgumentParser:
    # Common parent provides --json on every sub-command so callers can write
    # `buck-context list --json` (after the subcommand) as well as before.
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--json", action="store_true", help="machine-readable output")

    p = argparse.ArgumentParser(
        prog="buck-context",
        parents=[common],
        description="Persistent project context for the Claude / GPT / Codex workflow.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("init", parents=[common], help="register a project (default: CWD)")
    sp.add_argument("--path", help="project path (default: CWD)")
    sp.set_defaults(func=cmd_init)

    sp = sub.add_parser("status", parents=[common], help="brief project status")
    sp.add_argument("--session", help="path of project (default: CWD)")
    sp.set_defaults(func=cmd_status)

    sp = sub.add_parser("write", parents=[common], help="add a memory")
    sp.add_argument("category", help="must_do, do_dont, server_config, …")
    sp.add_argument("content", help="memory body")
    sp.add_argument("--key", help="short tag")
    sp.add_argument("--importance", type=int, default=5, help="1..10")
    sp.add_argument("--expires", help="duration: 7d, 24h, 15m, 90s")
    sp.add_argument("--global", dest="global_", action="store_true",
                    help="cross-project memory")
    sp.add_argument("--session", help="target project (default: CWD)")
    sp.set_defaults(func=cmd_write)

    sp = sub.add_parser("list", parents=[common], help="list memories")
    sp.add_argument("--cat", help="filter by category")
    sp.add_argument("--key", help="filter by key")
    sp.add_argument("--global", dest="global_", action="store_true")
    sp.add_argument("--session", help="restrict to specific project")
    sp.add_argument("--all-sessions", action="store_true",
                    help="search every project (shows project column)")
    sp.set_defaults(func=cmd_list)

    sp = sub.add_parser("update", parents=[common], help="replace a memory's content")
    sp.add_argument("id", type=int)
    sp.add_argument("content")
    sp.set_defaults(func=cmd_update)

    sp = sub.add_parser("delete", parents=[common], help="hard-delete a memory (audited)")
    sp.add_argument("id", type=int)
    sp.add_argument("--reason", help="audit note")
    sp.set_defaults(func=cmd_delete)

    sp = sub.add_parser("recap", parents=[common], help="markdown brief of project state")
    sp.add_argument("--max", type=int, default=20, help="cap rows per category")
    sp.add_argument("--global", dest="global_", action="store_true",
                    help="include cross-project memories")
    sp.add_argument("--session", help="recap a specific project")
    sp.set_defaults(func=cmd_recap)

    sp = sub.add_parser("search", parents=[common], help="LIKE-search memories")
    sp.add_argument("query")
    sp.add_argument("--cat", help="restrict to category")
    sp.add_argument("--session", help="restrict to specific project")
    sp.add_argument("--all-sessions", action="store_true")
    sp.set_defaults(func=cmd_search)

    sp = sub.add_parser("log", parents=[common], help="recent messages")
    sp.add_argument("--n", type=int, default=20)
    sp.add_argument("--since", help="ISO8601 cutoff")
    sp.add_argument("--session", help="restrict to specific project")
    sp.add_argument("--all-sessions", action="store_true")
    sp.set_defaults(func=cmd_log)

    sp = sub.add_parser("sessions", parents=[common], help="enumerate or show projects")
    ssub = sp.add_subparsers(dest="action", required=True)
    ssp = ssub.add_parser("list", parents=[common], help="list registered projects")
    ssp.set_defaults(func=cmd_sessions)
    ssp = ssub.add_parser("show", parents=[common], help="recap a specific project")
    ssp.add_argument("path", help="project path or unique substring")
    ssp.add_argument("--max", type=int, default=20)
    ssp.set_defaults(func=cmd_sessions)

    sp = sub.add_parser("compact", parents=[common],
                        help="lossily summarise old chat messages via Ollama; memories untouched")
    sp.add_argument("--chat-older", dest="chat_older", default="14d",
                    help="messages older than this become eligible (e.g. 14d, 24h)")
    sp.add_argument("--keep-last", dest="keep_last", type=int, default=200,
                    help="keep the last N messages per project regardless of age")
    sp.add_argument("--chunk-chars", dest="chunk_chars", type=int,
                    default=COMPACT_CHUNK_CHARS_DEFAULT,
                    help=f"chars per Ollama chunk (default {COMPACT_CHUNK_CHARS_DEFAULT})")
    sp.add_argument("--model", default=COMPACT_MODEL_DEFAULT,
                    help=f"Ollama model (default {COMPACT_MODEL_DEFAULT})")
    sp.add_argument("--ollama-host", dest="ollama_host", default=OLLAMA_URL_DEFAULT,
                    help="Ollama base URL (default $OLLAMA_HOST or http://localhost:11434)")
    sp.add_argument("--dry-run", dest="dry_run", action="store_true")
    sp.add_argument("--session", help="restrict to one project (default: CWD)")
    sp.add_argument("--all-sessions", dest="all_sessions", action="store_true",
                    help="compact every registered project")
    sp.set_defaults(func=cmd_compact)

    sp = sub.add_parser("archive", parents=[common],
                        help="snapshot project memories+messages into a compressed archive")
    sp.add_argument("--title", help="user title for the snapshot")
    sp.add_argument("--messages", type=int, default=200,
                    help="how many recent messages to include (-1 = all, 0 = none, default 200)")
    sp.add_argument("--session", help="project (default: CWD)")
    sp.set_defaults(func=cmd_archive)

    sp = sub.add_parser("archives", parents=[common],
                        help="manage archive snapshots: list / view / restore / delete / export / import")
    asub = sp.add_subparsers(dest="action", required=True)
    a = asub.add_parser("list", parents=[common])
    a.add_argument("--session", help="project (default: CWD)")
    a.set_defaults(func=cmd_archives)
    a = asub.add_parser("view", parents=[common])
    a.add_argument("id", type=int)
    a.add_argument("--raw", action="store_true",
                   help="emit decompressed JSON payload as-is")
    a.set_defaults(func=cmd_archives)
    a = asub.add_parser("restore", parents=[common])
    a.add_argument("id", type=int)
    a.add_argument("--into-project", dest="into_project",
                   help="target project path (default: archive's original project)")
    a.add_argument("--no-messages", dest="no_messages", action="store_true",
                   help="restore memories only, skip messages")
    a.set_defaults(func=cmd_archives)
    a = asub.add_parser("delete", parents=[common])
    a.add_argument("id", type=int)
    a.set_defaults(func=cmd_archives)
    a = asub.add_parser("export", parents=[common])
    a.add_argument("id", type=int)
    a.set_defaults(func=cmd_archives)
    a = asub.add_parser("import", parents=[common])
    a.add_argument("--into-project", dest="into_project",
                   help="target project path (default: from envelope)")
    a.set_defaults(func=cmd_archives)

    sp = sub.add_parser("push-gpt", parents=[common],
                        help="deliver recap to a GPT session in chunked READY/ACK/LOADED handoff")
    sp.add_argument("--channel", default="a", help="a|b|cursor|codex (default a)")
    sp.add_argument("--max-chunk", dest="max_chunk", type=int, default=20000,
                    help="max chars per chunk (default 20000)")
    sp.add_argument("--max", type=int, default=20, help="cap rows per category in recap")
    sp.add_argument("--global", dest="global_", action="store_true",
                    help="include cross-project memories")
    sp.add_argument("--no-messages", dest="no_messages", action="store_true",
                    help="omit recent conversation tail from recap")
    sp.add_argument("--retries", type=int, default=2,
                    help="ack retry attempts per step (default 2)")
    sp.add_argument("--resume-from", dest="resume_from", type=int, default=0,
                    help="skip ahead to this chunk (1-indexed); 0 = full run from preamble")
    sp.add_argument("--dry-run", dest="dry_run", action="store_true",
                    help="print chunk plan without sending anything")
    sp.add_argument("--session", help="project to push (default: CWD)")
    sp.set_defaults(func=cmd_push_gpt)

    sp = sub.add_parser("menu", parents=[common],
                        help="session-start menu (designed for AskUserQuestion)")
    sp.add_argument("--session", help="project path (default: CWD)")
    sp.set_defaults(func=cmd_menu)

    sp = sub.add_parser("message-add", parents=[common],
                        help="(internal) log a message — used by buck-review.sh")
    sp.add_argument("--direction", required=True, choices=["out", "in"])
    sp.add_argument("--agent", required=True,
                    help="user|claude|gpt|codex|buck (chatgpt/cursor mapped to gpt)")
    sp.add_argument("--channel")
    sp.add_argument("--status")
    sp.add_argument("--request-id", dest="request_id")
    sp.add_argument("--session", help="project path (default: CWD)")
    sp.add_argument("--content", help="message body")
    sp.add_argument("--content-stdin", action="store_true",
                    help="read content from stdin instead of --content")
    sp.add_argument("--tokens-in", dest="tokens_in", type=int)
    sp.add_argument("--tokens-out", dest="tokens_out", type=int)
    sp.set_defaults(func=cmd_message_add)

    sp = sub.add_parser("prune", parents=[common], help="delete expired memories")
    sp.add_argument("--dry-run", action="store_true")
    sp.set_defaults(func=cmd_prune)

    sp = sub.add_parser("doctor", parents=[common], help="schema + integrity check")
    sp.set_defaults(func=cmd_doctor)

    return p


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    # `--json` is on the top-level parser; all subcommands inherit it via Namespace.
    if not hasattr(args, "json"):
        args.json = False
    # `sessions` has nested action; consolidate so command code can read args.action.
    if args.cmd == "sessions" and not hasattr(args, "action"):
        args.action = None
    try:
        args.func(args)
    except sqlite3.Error as e:
        die(f"sqlite error: {e}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
